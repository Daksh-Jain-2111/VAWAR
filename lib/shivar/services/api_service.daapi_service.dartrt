  Future<Map<String, dynamic>> getAdvisory({
    required double latitude,
    required double longitude,
    String? cropType,
    String? fieldSize,
    String? season,
    double? ndviScore,
    Map<String, dynamic>? weatherData,
    List<List<double>>? polygon,
