import 'dart:convert';
import 'dart:developer' as developer;

import 'package:http/http.dart' as http;

import '../config/api_config.dart';

class ApiService {
  static final ApiService _instance = ApiService._internal();
  factory ApiService() => _instance;
  ApiService._internal();

  Future<Map<String, dynamic>> fetchNDVI(
    double latitude,
    double longitude, {
    List<List<double>>? polygon,
  }) async {
    try {
      final response = await http.post(
        Uri.parse(ApiConfig.getNdviUrl()),
        headers: {'Content-Type': 'application/json'},
        body: jsonEncode({
          'latitude': latitude,
          'longitude': longitude,
          'polygon': polygon,
        }),
      );

      if (response.statusCode == 200) {
        return jsonDecode(response.body) as Map<String, dynamic>;
      } else {
        throw Exception('Failed to fetch NDVI: ${response.statusCode}');
      }
    } catch (e) {
      developer.log(
        'Error fetching NDVI',
        name: 'ApiService.fetchNDVI',
        error: e,
      );
      rethrow;
    }
  }

  Future<Map<String, dynamic>> fetchWeather(
    double latitude,
    double longitude,
  ) async {
    try {
      final response = await http.post(
        Uri.parse(ApiConfig.getWeatherUrl()),
        headers: {'Content-Type': 'application/json'},
        body: jsonEncode({
          'latitude': latitude,
          'longitude': longitude,
        }),
      );

      if (response.statusCode == 200) {
        return jsonDecode(response.body) as Map<String, dynamic>;
      } else {
        throw Exception('Failed to fetch weather: ${response.statusCode}');
      }
    } catch (e) {
      developer.log(
        'Error fetching weather',
        name: 'ApiService.fetchWeather',
        error: e,
      );
      rethrow;
    }
  }

  Future<Map<String, dynamic>> getCropHealth(
    double latitude,
