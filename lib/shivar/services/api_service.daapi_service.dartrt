  Future<Map<String, dynamic>> detectDisease({
    required String imageData, // Base64 encoded
    double? latitude,
    double? longitude,
    String? cropType,
  }) async {
    try {
      final response = await http.post(
        Uri.parse('${ApiConfig.baseUrl}/api/disease-detection'),
        headers: {'Content-Type': 'application/json'},
        body: jsonEncode({
          'image_data': imageData,
          'latitude': latitude,
          'longitude': longitude,
          'crop_type': cropType,
